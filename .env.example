# Copy to .env (local) or set these as variables in Railway.
# All are optional — sensible defaults are baked in.

BASE_MODEL_ID=Qwen/Qwen2.5-0.5B-Instruct
MAX_NEW_TOKENS=256
TEMPERATURE=0.7
TOP_P=0.9

# Training
EPOCHS=3
LR=2e-4
BATCH_SIZE=1
GRAD_ACCUM=8
MAX_SEQ_LEN=512
LORA_R=16
LORA_ALPHA=32
LORA_DROPOUT=0.05
